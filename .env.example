# xAI / Grok
XAI_API_KEY=your_xai_api_key_here
XAI_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-3-fast
GROK_MINI_MODEL=grok-3-mini-fast

# Approval thresholds (USD)
AUTO_APPROVE_THRESHOLD=1000.0
MANAGER_APPROVAL_THRESHOLD=10000.0
DIRECTOR_APPROVAL_THRESHOLD=25000.0

# Risk thresholds (0-100 score)
HIGH_RISK_THRESHOLD=70
MEDIUM_RISK_THRESHOLD=30

# Extraction
MAX_EXTRACTION_RETRIES=3
MIN_CONFIDENCE_THRESHOLD=0.7

# Database
DB_PATH=inventory.db
